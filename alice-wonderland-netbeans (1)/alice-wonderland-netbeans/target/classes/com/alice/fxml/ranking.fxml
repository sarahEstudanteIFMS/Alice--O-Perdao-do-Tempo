<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="14.0" styleClass="root-menu" stylesheets="@../css/estilo.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.alice.controller.RankingController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label styleClass="titulo" text="🏆 Ranking do País das Maravilhas" />
    <Label fx:id="lblMensagem" styleClass="label-comum" text="" />

    <TableView fx:id="tabela" prefHeight="280" prefWidth="500">
        <columns>
            <TableColumn fx:id="colPos" prefWidth="60" text="#" />
            <TableColumn fx:id="colNome" prefWidth="200" text="Nome" />
            <TableColumn fx:id="colPontos" prefWidth="120" text="Melhor Pontuação" />
            <TableColumn fx:id="colPartidas" prefWidth="100" text="Partidas" />
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="15">
        <Button onAction="#onAtualizar" styleClass="botao-secundario" text="🔄 Atualizar" />
        <Button onAction="#onExportarCSV" styleClass="botao-secundario" text="⬇ Exportar CSV" />
        <Button onAction="#onExportarTXT" styleClass="botao-secundario" text="⬇ Exportar TXT" />
    </HBox>

    <Button onAction="#onVoltar" styleClass="botao-sair" text="⬅ Voltar ao Menu" />

</VBox>
