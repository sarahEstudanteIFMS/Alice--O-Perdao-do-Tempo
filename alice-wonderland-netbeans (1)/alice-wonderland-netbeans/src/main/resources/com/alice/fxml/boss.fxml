<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="root-jogo" stylesheets="@../css/estilo.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.alice.controller.BossController">

    <top>
        <HBox alignment="CENTER" spacing="40" styleClass="hud">
            <padding>
                <Insets bottom="10" left="20" right="20" top="10" />
            </padding>
            <Label styleClass="hud-texto" text="⏰ Confronto com o Tempo ⏰" />
            <Label fx:id="lblVidaAlice" styleClass="hud-texto" text="Alice: ❤ 3" />
            <Label fx:id="lblVidaBoss" styleClass="hud-texto" text="Tempo: 10 ⏰" />
        </HBox>
    </top>

    <center>
        <Pane alignment="CENTER" styleClass="painel-canvas">
            <Canvas fx:id="canvas" height="450.0" width="700.0" />
        </Pane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="8" styleClass="rodape-jogo">
            <padding>
                <Insets bottom="12" top="8" />
            </padding>
            <Label fx:id="lblStatus" styleClass="status-texto" text="Desvie do ponteiro vermelho e toque nos pontos verdes para enfraquecer o Tempo!" />
        </VBox>
    </bottom>

</BorderPane>
