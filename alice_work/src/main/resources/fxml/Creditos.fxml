<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16.0" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aliceoretorno.controller.Creditos"
      style="-fx-background-color: #1a0a2e; -fx-padding: 40;">

    <Label text="🎬  Créditos"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d4a8ff;"/>

    <Label text="Alice: O Retorno"
           style="-fx-font-size: 18px; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label text="Projeto Final — Programação Orientada a Objetos"
           style="-fx-font-size: 13px; -fx-text-fill: #aaaaaa;"/>

    <Label text="Desenvolvido com  ♥  em Java + JavaFX + PostgreSQL"
           style="-fx-font-size: 13px; -fx-text-fill: #aaaaaa; -fx-font-style: italic;"/>

    <Label text="Arquitetura MVC  •  Padrão DAO  •  JDBC"
           style="-fx-font-size: 12px; -fx-text-fill: #7755aa;"/>

    <Label text='"Quem sou eu? Ah, esse é o grande enigma!"'
           style="-fx-font-size: 13px; -fx-text-fill: #d4a8ff; -fx-font-style: italic;"/>
    <Label text="— Lewis Carroll, Alice no País das Maravilhas"
           style="-fx-font-size: 11px; -fx-text-fill: #7755aa;"/>

    <Button text="↩  Voltar ao Menu" onAction="#handleVoltar" prefWidth="200"
            style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8;"/>
</VBox>
