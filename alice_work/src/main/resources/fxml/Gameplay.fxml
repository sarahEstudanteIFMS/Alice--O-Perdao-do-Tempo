<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aliceoretorno.controller.Gameplay"
      style="-fx-background-color: #1a0a2e; -fx-padding: 30;">

    <Label text="Alice: O Retorno — Gameplay"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #d4a8ff;"/>

    <HBox spacing="30" alignment="CENTER">
        <Label fx:id="lblNivel"    text="Nível: 1 / 15"  style="-fx-text-fill: #a888cc; -fx-font-size: 14px;"/>
        <Label fx:id="lblSanidade" text="Sanidade: 3"     style="-fx-text-fill: #ff8888; -fx-font-size: 14px;"/>
        <Label fx:id="lblTimer"    text="Tempo: 40s"      style="-fx-text-fill: #ffdd55; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Label fx:id="lblDicas"    text="Dicas disponíveis: 0" style="-fx-text-fill: #88ccff; -fx-font-size: 14px;"/>
        <Label fx:id="lblEngrenagens" text="Engrenagens: 0" style="-fx-text-fill: #ffdd55; -fx-font-size: 14px;"/>
    </HBox>

    <Label fx:id="lblEnigma" text="..."
           wrapText="true" maxWidth="500"
           style="-fx-font-size: 16px; -fx-text-fill: white; -fx-text-alignment: center; -fx-background-color: #2d0f4e; -fx-padding: 16; -fx-background-radius: 10;"/>

    <TextField fx:id="txtResposta" promptText="Digite sua resposta aqui..."
               prefWidth="400"
               style="-fx-background-color: #2a1a3e; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-border-color: #6a0dad; -fx-border-radius: 6; -fx-background-radius: 6;"/>

    <HBox spacing="12" alignment="CENTER">
        <Button text="✔  Confirmar"       onAction="#handleConfirmar"       prefWidth="140"
                style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8;"/>
        <Button fx:id="btnDica" text="💡  Dica" onAction="#handleUsarDica" prefWidth="100"
                style="-fx-background-color: #2a5d8a; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8;"/>
        <Button text="🎒  Bolsa"    onAction="#handleAbrirInventario" prefWidth="120"
                style="-fx-background-color: #3d1a6e; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8;"/>
        <Button text="🛒  Loja"     onAction="#handleAbrirLoja" prefWidth="120"
                style="-fx-background-color: #8a5d2a; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8;"/>
    </HBox>

    <Button text="↩  Voltar ao Menu" onAction="#handleVoltarMenu" prefWidth="180"
            style="-fx-background-color: #4a0000; -fx-text-fill: #ffaaaa; -fx-font-size: 12px; -fx-background-radius: 8;"/>
</VBox>
