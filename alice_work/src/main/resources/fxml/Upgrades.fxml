<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16.0" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aliceoretorno.controller.Upgrades"
      style="-fx-background-color: #1a0a2e; -fx-padding: 28;">

    <Label text="🔧  Upgrades Permanentes"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #d4a8ff;"/>

    <Label fx:id="lblPontosUpgrade" text="Pontos Permanentes Disponíveis: 0"
           style="-fx-font-size: 14px; -fx-text-fill: #ffdd55;"/>

    <HBox spacing="16" alignment="CENTER">
        <VBox spacing="6" alignment="CENTER"
              style="-fx-background-color: #2d0f4e; -fx-padding: 12; -fx-background-radius: 10;">
            <Label fx:id="lblStatusSanidade" text="Sanidade Inicial Base: 3 HP"
                   style="-fx-font-size: 13px; -fx-text-fill: #ff8888;"/>
            <Button text="+1 Sanidade (1 ponto)" onAction="#handleUpgradeSanidade" prefWidth="200"
                    style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-background-radius: 8;"/>
        </VBox>
        <VBox spacing="6" alignment="CENTER"
              style="-fx-background-color: #2d0f4e; -fx-padding: 12; -fx-background-radius: 10;">
            <Label fx:id="lblStatusTempo" text="Tempo Base das Rodadas: 30s"
                   style="-fx-font-size: 13px; -fx-text-fill: #ffdd55;"/>
            <Button text="+5s Tempo (1 ponto)" onAction="#handleUpgradeTempo" prefWidth="200"
                    style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-background-radius: 8;"/>
        </VBox>
    </HBox>

    <Label text="🏆  Top 10 — Ranking Global"
           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #d4a8ff;"/>

    <ListView fx:id="listRanking" prefHeight="180" prefWidth="460"
              style="-fx-background-color: #2d0f4e; -fx-control-inner-background: #2d0f4e;
                     -fx-text-fill: white; -fx-border-color: #6a0dad; -fx-border-radius: 6;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="📄  Exportar TXT" onAction="#handleExportarTXT" prefWidth="180"
                style="-fx-background-color: #3d1a6e; -fx-text-fill: white; -fx-background-radius: 8;"/>
        <Button text="📊  Exportar CSV" onAction="#handleExportarCSV" prefWidth="180"
                style="-fx-background-color: #3d1a6e; -fx-text-fill: white; -fx-background-radius: 8;"/>
    </HBox>

    <Button text="↩  Voltar ao Menu" onAction="#handleVoltar" prefWidth="200"
            style="-fx-background-color: #4a0000; -fx-text-fill: #ffaaaa; -fx-font-size: 12px; -fx-background-radius: 8;"/>
</VBox>
