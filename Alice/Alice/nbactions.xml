<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <!-- Botão "Run Project" (F6) → mvn javafx:run -->
    <action>
        <actionName>run</actionName>
        <goals>
            <goal>javafx:run</goal>
        </goals>
    </action>
    <!-- Botão "Debug Project" -->
    <action>
        <actionName>debug</actionName>
        <goals>
            <goal>javafx:run</goal>
        </goals>
        <properties>
            <javafx.options>-agentlib:jdwp=transport=dt_socket,server=n,address=${jpda.address}</javafx.options>
        </properties>
    </action>
    <!-- Clean and Build -->
    <action>
        <actionName>build</actionName>
        <goals>
            <goal>compile</goal>
        </goals>
    </action>
</actions>
