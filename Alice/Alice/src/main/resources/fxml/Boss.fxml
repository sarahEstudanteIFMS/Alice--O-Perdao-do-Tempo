<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aliceoretorno.controller.Boss"
      style="-fx-background-color: #0d0005; -fx-padding: 30;">

    <Label text="⚔  O Confronto Final"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ff4466;"/>

    <Label text="O Tempo aguarda sua resposta..."
           style="-fx-font-size: 13px; -fx-text-fill: #aa4466; -fx-font-style: italic;"/>

    <Label fx:id="lblTimerBoss" text="Tempo Restante: 30s"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ffdd55;"/>

    <Label fx:id="lblEnigmaBoss" text="..."
           wrapText="true" maxWidth="500"
           style="-fx-font-size: 15px; -fx-text-fill: white; -fx-text-alignment: center;
                  -fx-background-color: #2a000a; -fx-padding: 16; -fx-background-radius: 10;"/>

    <TextField fx:id="txtRespostaBoss" promptText="Sua resposta final..."
               prefWidth="400"
               style="-fx-background-color: #1a000a; -fx-text-fill: white; -fx-prompt-text-fill: #888;
                      -fx-border-color: #ff4466; -fx-border-radius: 6; -fx-background-radius: 6;"/>

    <Button text="🗡  Decifrar o Enigma Final" onAction="#handleFinalizarBoss" prefWidth="240"
            style="-fx-background-color: #8b0000; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 8;"/>
</VBox>
